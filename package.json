{
  "name": "spacemolt-commander",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "dev:web": "cd web && bun run dev",
    "build:web": "cd web && bun run build",
    "gen:types": "bunx openapi-typescript openapi.json -o src/types/generated/api.ts",
    "test": "bun test",
    "db:reset": "rm -f data/commander.db && bun run src/data/database.ts"
  },
  "dependencies": {
    "toml": "^3.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "bun-types": "^1.2.0",
    "openapi-typescript": "^7.6.0",
    "typescript": "^5.7.0"
  }
}
